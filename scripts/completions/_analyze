#compdef analyze.py ./analyze.py

local context state state_descr line
typeset -A opt_args

_analyze_indices() {
	local -a indices
	if [[ -x "./analyze.py" ]]; then
		indices=($(./analyze.py --list-indices 2>/dev/null))
	fi
	
	if [[ -n "$indices" ]]; then
		_describe -t indices 'indices' indices
	fi
}

_analyze_profiles() {
	local -a profiles
	if [[ -x "./analyze.py" ]]; then
		profiles=($(./analyze.py --list-profiles 2>/dev/null))
	fi

	if [[ -n "$profiles" ]]; then
		_describe -t profiles 'profiles' profiles
	else
		local -a defaults
		defaults=(balanced growth dividend)
		_describe -t profiles 'profiles' defaults
	fi
}

_arguments -s -S \
	'*:ticker:_files' \
	'(-f --file)'{-f,--file}'[Path to a file containing tickers]:ticker file:_files' \
	'(-i --index)'{-i,--index}'[Ticker of an index/ETF to analyze its components]:index ticker:_analyze_indices' \
	'(-a --all)'{-a,--all}'[Analyze all assets currently in the database]' \
	'(-p --profile)'{-p,--profile}'[Investment profile to use]:profile:_analyze_profiles' \
	'--benchmark-version[Version of benchmarks to use for analysis]:version: ' \
	'(-e --export)'{-e,--export}'[Export format]:format:(csv txt)' \
	'--history[Show historical scores for the provided ticker(s)]' \
	'(-v --verbose)'{-v,--verbose}'[Enable verbose output]' \
	'(-b --background)'{-b,--background}'[Run the analysis in the background]' \
	'--db[Inspect the database]:view:(assets indices snapshots sectors profiles benchmarks inventory)' \
	'--help[Show help message]'
